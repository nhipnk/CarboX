{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "ignoreDeprecations": "6.0",
    "types": ["node", "mocha", "chai"]
  },
  "include": ["contracts", "test", "ignition"],
  "exclude": ["node_modules"]
}