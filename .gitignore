# ============================================================
# .gitignore — CARBOX monorepo
# ============================================================

# ── Node modules (tất cả packages) ───────────────────────────
**/node_modules
/.pnp
.pnp.js

# ── Environment files ─────────────────────────────────────────
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Smart Contract (Hardhat) ──────────────────────────────────
/smart-contract/artifacts
/smart-contract/cache
/smart-contract/types
/smart-contract/dist
/smart-contract/bundle
/smart-contract/.gas-snapshot
/smart-contract/snapshots

# ── Frontend (Next.js) ────────────────────────────────────────
/frontend/.next/
/frontend/out/
/frontend/build
/frontend/.vercel

# ── Testing & Coverage ────────────────────────────────────────
**/coverage

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo

# ── Logs ─────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── OS ────────────────────────────────────────────────────────
.DS_Store
*.pem